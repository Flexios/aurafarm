# Supabase (required for cloud auth + saves)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: AI Aura Judge (server-only on Vercel; also used by `npm run dev` proxy)
XAI_API_KEY=

# Optional: streak email reminders (Vercel server + cron)
# SUPABASE_SERVICE_ROLE_KEY=from Supabase → Settings → API → service_role
# SUPABASE_URL=same as VITE_SUPABASE_URL (or rely on VITE_SUPABASE_URL)
# CRON_SECRET=long random string (Authorization: Bearer …)
# RESEND_API_KEY=from resend.com
# EMAIL_FROM=AuraFarm <onboarding@resend.dev>
# APP_URL=https://aurafarm-chi.vercel.app
