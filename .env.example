# Supabase (required for cloud auth + saves)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional AI (server-only on Vercel; also used by `npm run dev` proxy)
# Any ONE of these is enough — tried in order: xAI → Groq → Gemini → Ollama
#
# SpaceXAI / xAI (paid credits): https://console.x.ai
XAI_API_KEY=
# XAI_MODEL=grok-4.5
#
# OpenRouter (free models): https://openrouter.ai/keys
# Model: openrouter/free (auto free router) or e.g. meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# OPENROUTER_SITE_URL=https://your-app.vercel.app
#
# Groq free tier: https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
#
# Local free unlimited (dev only — install Ollama + pull a model):
#   ollama pull llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_ENABLED=1

# Optional: streak email reminders (Vercel server + cron)
# SUPABASE_SERVICE_ROLE_KEY=from Supabase → Settings → API → service_role
# SUPABASE_URL=same as VITE_SUPABASE_URL (or rely on VITE_SUPABASE_URL)
# CRON_SECRET=long random string (Authorization: Bearer …)
# RESEND_API_KEY=from resend.com
# EMAIL_FROM=AuraFarm <onboarding@resend.dev>
# APP_URL=https://aurafarm-chi.vercel.app
